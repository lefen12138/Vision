<!-- 
    MainWindow.xaml —— 视觉感知虚拟实验平台主界面
    
    布局结构：
    ┌─────────────────────────────────────────────┐
    │  工具栏（打开摄像头/视频 | 加载标定文件）      │
    ├──────────────┬──────────────┬───────────────┤
    │  原始输入预览 │  检测结果可视 │  参数控制面板  │
    │   （实时帧）  │ （边框/标注） │ （滑块/输入框）│
    ├──────────────┴──────────────┴───────────────┤
    │  状态栏（FPS | 当前状态 | 版本信息）          │
    └─────────────────────────────────────────────┘
-->
<Window x:Class="VisionWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="视觉感知虚拟实验平台 | 哈工大(威海) 大一年度项目"
        Height="740" Width="1300"
        MinHeight="600" MinWidth="1050"
        Background="#FF1E1E2E"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing">

    <Window.Resources>
        <!-- 暗色科技风格主题 -->
        <Style x:Key="DarkLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,2"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFA6E3A1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="3,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ParamTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF45475A"/>
            <Setter Property="Foreground" Value="#FFA6E3A1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#FF6C7086"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF89B4FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>    <!-- 工具栏 -->
            <RowDefinition Height="*"/>     <!-- 主内容 -->
            <RowDefinition Height="26"/>    <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ======================================================
             顶部工具栏
        ====================================================== -->
        <Border Grid.Row="0" Background="#FF1E66F5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- 品牌标题 -->
                <TextBlock Text="🔬  视觉感知虚拟实验平台"
                           Foreground="White" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="14,0,16,0"/>

                <Rectangle Width="1" Fill="#4DFFFFFF" Margin="0,8"/>

                <!-- 输入源控制 -->
                <Button x:Name="btnOpenCamera"
                        Content="📷  打开摄像头"
                        Click="BtnOpenCamera_Click"
                        Style="{StaticResource ToolBtn}"
                        Background="#FF179299"/>

                <Button x:Name="btnOpenVideo"
                        Content="🎬  打开视频"
                        Click="BtnOpenVideo_Click"
                        Style="{StaticResource ToolBtn}"
                        Background="#FF179299"/>

                <Button x:Name="btnStop"
                        Content="⏹  停止"
                        Click="BtnStop_Click"
                        IsEnabled="False"
                        Style="{StaticResource ToolBtn}"
                        Background="#FFE64553"/>

                <Rectangle Width="1" Fill="#4DFFFFFF" Margin="6,8"/>

                <!-- 配置文件 -->
                <Button Content="📁  标定文件"
                        Click="BtnLoadCalib_Click"
                        Style="{StaticResource ToolBtn}"
                        Background="#FF40A02B"/>

                <Button Content="📋  Hu矩模板"
                        Click="BtnLoadHuTemplate_Click"
                        Style="{StaticResource ToolBtn}"
                        Background="#FF40A02B"/>

                <Rectangle Width="1" Fill="#4DFFFFFF" Margin="6,8"/>

                <!-- DLL 状态指示 -->
                <Ellipse x:Name="dllStatusDot"
                         Width="10" Height="10" Fill="#FFE64553"
                         VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock x:Name="txtDllStatus"
                           Text="DLL 未加载" Foreground="White"
                           FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ======================================================
             主内容区域（三列布局）
        ====================================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>  <!-- 原始输入 -->
                <ColumnDefinition Width="2*" MinWidth="300"/>  <!-- 检测结果 -->
                <ColumnDefinition Width="290"/>                 <!-- 参数面板 -->
            </Grid.ColumnDefinitions>

            <!-- ======== 左列：原始输入视频 ======== -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📹  原始输入"
                               Grid.Row="0" Style="{StaticResource SectionTitle}"/>

                    <Border Grid.Row="1" Background="#FF1E1E2E" CornerRadius="4">
                        <Image x:Name="imgOriginal"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ======== 中列：处理结果可视化 ======== -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🔍  检测结果（边框/标注）"
                               Grid.Row="0" Style="{StaticResource SectionTitle}"/>

                    <Border Grid.Row="1" Background="#FF1E1E2E" CornerRadius="4">
                        <Image x:Name="imgProcessed"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ======== 右列：参数控制面板 ======== -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ─── 算法参数卡片 ─── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="⚙️  算法参数" Style="{StaticResource SectionTitle}"/>

                            <!-- 小波尺度滑块 -->
                            <Label Content="小波检测尺度（scales）" Style="{StaticResource DarkLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="sliderWaveletScales"
                                        Minimum="1" Maximum="6" Value="3"
                                        SmallChange="1" LargeChange="1"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="SliderWaveletScales_ValueChanged"
                                        Foreground="#FF1E66F5"/>
                                <TextBlock x:Name="txtWaveletScales"
                                           Grid.Column="1" Text="3"
                                           Style="{StaticResource ValueText}"
                                           TextAlignment="Center"/>
                            </Grid>

                            <!-- Hu 矩识别阈值 -->
                            <Label Content="Hu 矩识别阈值（threshold）"
                                   Style="{StaticResource DarkLabel}" Margin="0,8,0,0"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="sliderHuThreshold"
                                        Minimum="0.05" Maximum="1.0" Value="0.3"
                                        SmallChange="0.05" LargeChange="0.1"
                                        ValueChanged="SliderHuThreshold_ValueChanged"
                                        Foreground="#FF1E66F5"/>
                                <TextBlock x:Name="txtHuThreshold"
                                           Grid.Column="1" Text="0.30"
                                           Style="{StaticResource ValueText}"
                                           TextAlignment="Center"/>
                            </Grid>

                            <!-- 像素当量 -->
                            <Label Content="像素当量（mm/pixel）"
                                   Style="{StaticResource DarkLabel}" Margin="0,8,0,0"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="cmbTargetType"
                                          Margin="0,0,4,0"
                                          Background="#FF45475A" Foreground="#FFCDD6F4"
                                          SelectionChanged="CmbTargetType_SelectionChanged">
                                    <ComboBoxItem Content="齿轮 (gear)" Tag="gear" IsSelected="True"/>
                                    <ComboBoxItem Content="螺母 (nut)"  Tag="nut"/>
                                    <ComboBoxItem Content="默认"        Tag="default"/>
                                </ComboBox>
                                <TextBox x:Name="txtPixelEquiv"
                                         Grid.Column="1" Text="0.05"
                                         Style="{StaticResource ParamTextBox}"
                                         LostFocus="TxtPixelEquiv_LostFocus"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ─── 齿轮测量参数卡片 ─── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="⚙️  齿轮公法线测量" Style="{StaticResource SectionTitle}"/>

                            <Label Content="总齿数 z" Style="{StaticResource DarkLabel}"/>
                            <TextBox x:Name="txtToothCount" Text="20"
                                     Style="{StaticResource ParamTextBox}"/>

                            <Label Content="模数 m（mm）"
                                   Style="{StaticResource DarkLabel}" Margin="0,6,0,0"/>
                            <TextBox x:Name="txtModule" Text="2.0"
                                     Style="{StaticResource ParamTextBox}"/>

                            <Label Content="跨测齿数 k（0=自动推荐）"
                                   Style="{StaticResource DarkLabel}" Margin="0,6,0,0"/>
                            <TextBox x:Name="txtSpanTeeth" Text="0"
                                     Style="{StaticResource ParamTextBox}"/>

                            <Button Content="▶  计算公法线长度"
                                    Click="BtnCalculateNormal_Click"
                                    Margin="0,10,0,0" Padding="0,8"
                                    Background="#FF1E66F5" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12"/>

                            <!-- 公法线结果 -->
                            <Border Background="#FF1E1E2E" CornerRadius="4"
                                    Margin="0,6,0,0" Padding="8">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="W = " Foreground="#FF89B4FA"
                                               FontSize="16" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtNormalResult" Text="—"
                                               Foreground="#FFF38BA8" FontFamily="Consolas"
                                               FontSize="20" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" mm" Foreground="#FF89B4FA"
                                               FontSize="14" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ─── 实时检测结果卡片 ─── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="📊  实时检测结果" Style="{StaticResource SectionTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                </Grid.RowDefinitions>

                                <!-- 类别 -->
                                <Label Content="类别：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="0"/>
                                <TextBlock x:Name="txtResultClass" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="0" Grid.Column="1"/>

                                <!-- 中心坐标 -->
                                <Label Content="中心 X：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="1"/>
                                <TextBlock x:Name="txtResultCX" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="1" Grid.Column="1"/>

                                <Label Content="中心 Y：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="2"/>
                                <TextBlock x:Name="txtResultCY" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="2" Grid.Column="1"/>

                                <!-- 物理尺寸 -->
                                <Label Content="宽度(mm)：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="3"/>
                                <TextBlock x:Name="txtResultW" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="3" Grid.Column="1"/>

                                <Label Content="高度(mm)：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="4"/>
                                <TextBlock x:Name="txtResultH" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="4" Grid.Column="1"/>

                                <!-- 旋转角度 -->
                                <Label Content="角度(°)：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="5"/>
                                <TextBlock x:Name="txtResultAngle" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="5" Grid.Column="1"/>

                                <!-- 公法线 -->
                                <Label Content="公法线(mm)：" Style="{StaticResource DarkLabel}"
                                       Grid.Row="6"/>
                                <TextBlock x:Name="txtResultNL" Text="—"
                                           Style="{StaticResource ValueText}"
                                           Grid.Row="6" Grid.Column="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ─── FPS 卡片 ─── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="FPS "
                                       Foreground="#FF89B4FA" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtFPS" Text="0.0"
                                       Foreground="#FFFAB387" FontFamily="Consolas"
                                       FontSize="22" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ======================================================
             底部状态栏
        ====================================================== -->
        <StatusBar Grid.Row="2" Background="#FF181825">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus"
                           Text="就绪 | 请打开摄像头或视频文件开始检测"
                           Foreground="#FF6C7086" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtVersion"
                           Foreground="#FF45475A" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
